# Local dev (SQLite). On Railway, use PostgreSQL — see DEPLOYMENT.md.
# SQLite:  file:./dev.db
# Postgres: postgresql://user:pass@host:5432/railway  (set automatically when you add Railway Postgres)
DATABASE_URL="file:./dev.db"

# LLM (OpenRouter)
OPENROUTER_API_KEY=""
# Set to your Railway public URL in production, e.g. https://rivatutor.up.railway.app
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_APP_TITLE="Riva Teacher POC"

# Text-to-speech provider: openrouter (streaming PCM), vertex, or elevenlabs
TTS_PROVIDER="openrouter"

# OpenRouter TTS (default — streams PCM for chunk-by-chunk playback)
OPENROUTER_TTS_MODEL="google/gemini-3.1-flash-tts-preview"
OPENROUTER_TTS_VOICE="Kore"
# Style/persona prefix prepended to spoken text (defaults to friendly teacher with subtle Indian accent)
OPENROUTER_TTS_VOICE_PROMPT="The voice should balance three qualities: a friendly conversation partner, a teacher, and a real human speaker. Accent should be very subtle indian."

# Gemini / Vertex TTS (Google AI API key from AI Studio; works with API key auth)
# Get a key: https://aistudio.google.com/apikey
VERTEX_API_KEY=""
# TTS model: gemini-3.1-flash-tts-preview, gemini-2.5-pro-preview-tts
VERTEX_TTS_MODEL="gemini-3.1-flash-tts-preview"
# Prebuilt voice name, e.g. Kore, Puck, Charon — see Gemini TTS voice list
VERTEX_TTS_VOICE="Kore"
# Style/persona prefix prepended to spoken text (defaults to friendly teacher with subtle Indian accent)
VERTEX_TTS_VOICE_PROMPT="The voice should balance three qualities: a friendly conversation partner, a teacher, and a real human speaker. Accent should be very subtle indian."

# Speech-to-text (ElevenLabs Scribe — always used for STT)
ELEVENLABS_API_KEY=""
ELEVENLABS_STT_MODEL="scribe_v2"
ELEVENLABS_STT_LANGUAGE="eng"

# ElevenLabs TTS (only when TTS_PROVIDER=elevenlabs)
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
ELEVENLABS_TTS_MODEL="eleven_multilingual_v2"
ELEVENLABS_TTS_OUTPUT_FORMAT="mp3_44100_128"
