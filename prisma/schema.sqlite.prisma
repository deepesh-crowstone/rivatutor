// SQLite schema for local development (default).
// Copied to schema.prisma when DATABASE_URL is not a Postgres connection string.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model LearnerProfile {
  id                  String           @id @default(cuid())
  username            String           @unique
  name                String?
  selfDeclaredLevel   String?
  intentRaw           String?
  intentSummary       String?
  intentGoalContexts  String           @default("[]")
  intentMotivation    String?
  intentClarityStatus String           @default("unknown")
  intentProbeCount    Int              @default(0)
  userInterests       String           @default("[]")
  extractedKeyFacts   String           @default("[]")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  progress            LearnerProgress?
  topics              Topic[]
  messages            ChatMessage[]
}

model LearnerProgress {
  id                String         @id @default(cuid())
  learnerId         String         @unique
  activeTopicId     String?
  currentStepOrder  Int            @default(0)
  completedTopicIds String         @default("[]")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  learner           LearnerProfile @relation(fields: [learnerId], references: [id], onDelete: Cascade)
}

model Topic {
  id          String          @id @default(cuid())
  learnerId   String
  title       String
  description String
  order       Int
  status      String          @default("pending")
  source      String          @default("planned")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  learner     LearnerProfile  @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  lessonPlan  LessonPlan?
  messages    ChatMessage[]

  @@index([learnerId, order])
  @@index([learnerId, status])
}

model LessonPlan {
  id             String       @id @default(cuid())
  topicId        String       @unique
  level          String
  intentSnapshot String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  topic          Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  steps          LessonStep[]
}

model LessonStep {
  id             String     @id @default(cuid())
  lessonPlanId   String
  order          Int
  type           String
  questionType   String?
  content        String
  expectedAnswer String?
  completed      Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  lessonPlan     LessonPlan @relation(fields: [lessonPlanId], references: [id], onDelete: Cascade)

  @@unique([lessonPlanId, order])
}

model ChatMessage {
  id        String          @id @default(cuid())
  learnerId String
  topicId   String?
  role      String
  kind      String          @default("chat")
  content   String
  metadata  String?
  createdAt DateTime        @default(now())
  learner   LearnerProfile  @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  topic     Topic?          @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([learnerId, createdAt])
  @@index([topicId, createdAt])
}
